{
  "expo": {
    "name": "PlantFinder",
    "slug": "plant-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D6A4F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "package": "com.plantfinder.app"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Used to photograph plants for identification",
        "NSPhotoLibraryUsageDescription": "Used to select plant photos for identification"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PlantFinder to access your camera to photograph plants."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PlantFinder to access your photos to identify plants."
        }
      ]
    ]
  }
}
